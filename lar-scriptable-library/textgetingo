# 控制台清屏
# ==========================
def clear_screen():
    """
    ANSI 控制台清屏并复位光标
     | 等效 cmd cls 无闪烁
    """
    print(chr(27) + "[2J", end="")
    print(chr(27) + "[H", end="")


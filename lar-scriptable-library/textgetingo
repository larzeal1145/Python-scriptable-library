# ==========================
# 鼠标滚轮 内部实现
# ==========================
@digital_convert
def _check_wheel_change():
    """
    检测鼠标滚轮状态
     | 返回格式---------------------------> forward / backward / stop
    """
    global _wheel_last
    delta = user32.GetAsyncKeyState(0x142)
    current = (delta >> 16) & 0xFFFF

    if current != _wheel_last:
        if current > 0:
            res = "forward"
        elif current < 0:
            res = "backward"
        else:
            res = "stop"
        _wheel_last = current
        return res

# 对外封装接口
def check_wheel_change():
    """
    检测鼠标滚轮状态
     | 返回格式---------------------------> forward / backward / stop
    """
    res = _check_wheel_change()
    if res is not None:
        return res

# ==========================
# 鼠标移动增量 内部实现
# ==========================
def _get_mouse_delta():
    """
    获取鼠标相对移动增量
     | 支持快速网格模式节流
     | 返回格式---------------------------> (dx, dy)
    """
    global _last_x, _last_y, _last_gx, _last_gy
    pt = POINT()
    user32.GetCursorPos(ctypes.byref(pt))
    x = pt.x
    y = pt.y

    if _last_x is None:
        _last_x = x
        _last_y = y
        _last_gx = x // GRID
        _last_gy = y // GRID
        return 0, 0

    if not _enable_fast_relative:
        dx = x - _last_x
        dy = y - _last_y
        _last_x = x
        _last_y = y
        return dx, dy

    gx = x // GRID
    gy = y // GRID
    if gx == _last_gx and gy == _last_gy:
        return 0, 0

    dx = x - _last_x
    dy = y - _last_y
    _last_x = x
    _last_y = y
    _last_gx = gx
    _last_gy = gy
    return dx * GRID, dy * GRID

# 对外封装接口
def get_mouse_delta():
    """
    获取鼠标相对移动增量
     | 支持快速网格模式节流
     | 返回格式---------------------------> (dx, dy)
    """
    return _get_mouse_delta()

# ==========================
# 获取鼠标绝对坐标 内部实现
# ==========================
def _get_mouse_point():
    """
    获取鼠标当前绝对屏幕坐标
     | 返回格式---------------------------> [鼠标] x 数值 y 数值
    """
    pt = POINT()
    user32.GetCursorPos(ctypes.byref(pt))
    return f"[鼠标] x {pt.x} y {pt.y}"

# 对外封装接口
def get_mouse_point():
    """
    获取鼠标当前绝对屏幕坐标
     | 返回格式---------------------------> [鼠标] x 数值 y 数值
    """
    return _get_mouse_point()


if __name__ == '__main__':
    while True:
        key = check_key()
        ml = check_mouse_left_change()
        mr = check_mouse_right_change()
        mm = check_mouse_middle_change()
        wheel = check_wheel_change()
        dx, dy = get_mouse_delta()

        if key:
            print(key)
        if ml:
            print(ml)
        if mr:
            print(mr)
        if mm:
            print(mm)
        if wheel:
            print(wheel)
        if dx != 0 or dy != 0:
            print(f"[鼠标移动] dx={dx}, dy={dy}")

        time.sleep(0.01)